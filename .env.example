# ── Perlunas CMS / backend API ─────────────────────────────────────────
# Base URL of the Perlunas backend. Catalog/content pages fetch from here at
# request time and fall back to the bundled static data when it's unreachable.
# Leads are also forwarded (best-effort) to ${API_BASE_URL}/api/messages.
API_BASE_URL=http://localhost:5080

# Shared secret for the on-demand ISR webhook at /api/revalidate. The backend
# calls ${SITE_URL}/api/revalidate?secret=... after every content mutation to
# purge the ISR cache. MUST match the backend's SITE_REVALIDATE_SECRET.
REVALIDATE_SECRET=perlunas-revalidate-secret-2026

# ── Lead delivery (Google Sheets via Apps Script Web App) ───────────────
# Deploy the script in /scripts/google-apps-script.js as a Web App
# (Execute as: Me, Access: Anyone) and paste the deployment URL here.
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional shared secret — must match the SECRET constant inside the
# Apps Script so only your site can write to the sheet.
LEAD_WEBHOOK_SECRET=

# ── Public contact channels (used for the post-submit redirect) ─────────
# Zalo: your Zalo number or zalo.me short link id
NEXT_PUBLIC_ZALO_URL=https://zalo.me/0900000000
# Messenger: m.me/<page-username>
NEXT_PUBLIC_MESSENGER_URL=https://m.me/hanhtrinhviet
NEXT_PUBLIC_PHONE=0900000000
NEXT_PUBLIC_SITE_URL=https://hanhtrinhviet.vercel.app
